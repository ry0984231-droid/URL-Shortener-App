<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: rgb(0, 0, 33);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
            color: #e5e7eb;
        }

        h1 {
            margin-bottom: 25px;
            font-size: 2.4rem;
        }

        form {
            background: rgba(255, 255, 255, 0.08);
            padding: 20px 25px;
            border-radius: 12px;
        }

        label {
            display: block;
            margin-bottom: 8px;
        }

        input {
            width: 260px;
            padding: 10px;
            border-radius: 8px;
            border: none;
            outline: none;
            margin-right: 10px;
        }

        button {
            padding: 10px 16px;
            border: none;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.25);
            color: white;
            cursor: pointer;
            font-weight: bold;
        }

        table {
            margin-top: 30px;
            border-collapse: collapse;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            overflow: hidden;
        }

        th,
        td {
            padding: 12px 18px;
            text-align: center;
        }

        th {
            background: rgba(0, 0, 0, 0.25);
        }

        tbody tr:hover {
            background: rgba(255, 255, 255, 0.15);
        }
    </style>
</head>

<body>
    <h1>URL SHORTNER</h1>
    <% if (locals.id) { %>
        <p>
            URL Generated: http://localhost:8002/<%= id %>
        </p>
        <% } %>


            <form action="/url" method="POST">
                <label>Enter Your Original URL:</label>
                <input type="text" name="url" placeholder="https://example.com" required>
                <button type="submit">Generate</button>
            </form>

            <% if (locals.urls) { %>
                <table border="1">
                    <thead>
                        <tr>
                            <th>S.No</th>
                            <th>ShortID</th>
                            <th>Redirect URL</th>
                            <th>Clicks</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% urls.forEach((url, index)=> { %>
                            <tr>
                                <td>
                                    <%= index + 1 %>
                                </td>
                                <td>
                                    <%= url.shortId %>
                                </td>
                                <td>
                                    <%= url.redirecturl %>
                                </td>
                                <td>
                                    <%= url.visitHistory.length %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
                <% } %>

</body>

</html>